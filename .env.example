# Bastion Audit - Environment Variables

# Gemini API Key (Optional if using OpenRouter)
GEMINI_API_KEY=

# Lakera Guard API Key (Required for real-time security scanning)
# Get yours at: https://app.lakera.ai/
LAKERA_GUARD_API_KEY=

# OpenRouter API Key (Required for multi-model chat support)
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=
